# Example backend .env file
NODE_ENV=development
PORT=5001
PUBLIC_URL=http://localhost:3000

# MongoDB connection string
DATABASE_URL=mongodb://127.0.0.1:27017/freelancex

# JWT secrets
JWT_SECRET=replace-with-your-jwt-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace-with-your-refresh-secret
JWT_REFRESH_EXPIRES_IN=7d

# Cloudinary (file storage)
CLOUDINARY_CLOUD_NAME=replace-with-your-cloudinary-cloud-name
CLOUDINARY_API_KEY=replace-with-your-cloudinary-api-key
CLOUDINARY_API_SECRET=replace-with-your-cloudinary-api-secret
CLOUDINARY_FOLDER=your-brand

# Stripe
STRIPE_SECRET_KEY=replace-with-your-stripe-secret-key
